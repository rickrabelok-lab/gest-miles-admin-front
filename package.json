{
  "name": "gest-miles-monorepo",
  "private": true,
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "check:boundaries": "node check-app-boundaries.mjs",
    "import:airports": "node scripts/import-airports.mjs",
    "dev:client": "turbo run dev --filter=client-app",
    "dev:manager": "turbo run dev --filter=manager-app",
    "dev:admin": "turbo run dev --filter=admin-app"
  },
  "devDependencies": {
    "turbo": "^2.0.12"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.0",
    "csv-parse": "^6.2.1"
  }
}

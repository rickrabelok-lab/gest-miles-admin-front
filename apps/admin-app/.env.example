# Copie para .env.local e preencha (Supabase → Settings → API).
# Nomes têm de ser exatamente estes: SUPABASE com "O" (não SUPBASE).

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Opcional: health check de APIs externas no painel Operacional (URLs separadas por vírgula; requer CORS).
# VITE_ADMIN_EXTERNAL_HEALTH_URLS=https://api.example.com/health,https://status.other.com/ping

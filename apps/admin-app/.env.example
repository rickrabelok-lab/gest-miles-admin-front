# Copie para .env.local e preencha (Supabase → Settings → API).
# Nomes: VITE_SUPABASE_* (com "O" em SUPABASE).

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Opcional: BFF / API HTTP (ex.: endpoint /api/audit-logs). Sem isto, a página Logs usa `logs_acoes` via Supabase.
# VITE_API_URL=http://localhost:3000

# Opcional: health check de APIs externas no painel (URLs separadas por vírgula; requer CORS no destino)
# VITE_ADMIN_EXTERNAL_HEALTH_URLS=https://api.example.com/health,https://status.other.com/ping

# URL do Gestor Miles (manager) para abrir carteira/perfil do utilizador numa nova aba a partir do admin (ex.: http://localhost:3000).
# VITE_MANAGER_APP_URL=http://localhost:3000

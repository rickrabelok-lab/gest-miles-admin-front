# Copie para .env.local e preencha (Supabase → Settings → API).
# Nomes: VITE_SUPABASE_* (com "O" em SUPABASE).

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Opcional: BFF / API HTTP (Express): audit logs extra, e Monetização Stripe completa (/api/stripe/admin/*).
# Sem isto, a página Monetização Stripe mostra assinaturas a partir da tabela `subscriptions` no Supabase (só leitura).
#
# Em desenvolvimento, pedidos de http://localhost:3001 → http://localhost:3000 falham com "Failed to fetch" se o Express
# não enviar CORS. Solução: proxy no Vite + mesmo origin:
#   VITE_API_USE_SAME_ORIGIN=1
#   VITE_API_PROXY_TARGET=http://localhost:3040
# (porta do Express; evite usar a mesma porta do Vite admin.)
# Produção / preview sem proxy: URL absoluta do API:
#   VITE_API_URL=https://api.seudominio.com
# VITE_API_URL=http://localhost:3040

# Opcional: health check de APIs externas no painel (URLs separadas por vírgula; requer CORS no destino)
# VITE_ADMIN_EXTERNAL_HEALTH_URLS=https://api.example.com/health,https://status.other.com/ping

# URL do Gestor Miles (manager) para abrir carteira/perfil/pesquisa de passagens numa nova aba a partir do admin (ex.: http://localhost:3000).
# VITE_MANAGER_APP_URL=http://localhost:3000

# Copie para .env.local (ou .env) na raiz deste app e preencha.

# --- Supabase (browser) — obrigatório ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- BFF opcional (Express, ex. usuario-front/backend) ---
# VITE_API_URL=http://localhost:3000

# --- Cabeçalho /cs e painel gestor ---
# VITE_GESTAO_NOME_EMPRESA=Minha empresa

# Legado: api.ts também lê API_URL se existir
# API_URL=http://localhost:3000

# --- Backend Express (se correr backend neste repo; variáveis sem VITE_ no processo Node) ---
# PORT=3000
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
